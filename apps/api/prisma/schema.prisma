generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum ApplicationType {
  WEBSITE
  LANDING_PAGE
  ECOMMERCE
  PLATAFORMA_WEB
  APLICATIVO_MOBILE
  SISTEMA_INTERNO
  AUTOMACAO
  OUTRO
}

enum ProjectStatus {
  PROSPECCAO
  PREPARACAO
  EM_EXECUCAO
  CONCLUIDO
  CANCELADO
}

enum BudgetStatus {
  RASCUNHO
  FINALIZADO
  ENVIADO
  APROVADO
  RECUSADO
  CANCELADO
}

enum PricingConfigType {
  FIXED_VALUE
  UNIT_VALUE
  MULTIPLIER
  PERCENTAGE
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String    @db.VarChar(120)
  email               String    @unique @db.VarChar(254)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  role                UserRole  @default(USER)
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  responsibleProjects Project[] @relation("ProjectResponsible")
  createdBudgets      Budget[]  @relation("BudgetCreator")

  @@map("users")
}

model Project {
  id                String          @id @default(uuid()) @db.Uuid
  name              String          @db.VarChar(160)
  clientName        String?         @map("client_name") @db.VarChar(160)
  description       String?         @db.Text
  applicationType   ApplicationType @map("application_type")
  status            ProjectStatus   @default(PROSPECCAO)
  responsibleUserId String          @map("responsible_user_id") @db.Uuid
  notes             String?         @db.Text
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  responsibleUser   User            @relation("ProjectResponsible", fields: [responsibleUserId], references: [id])
  budgets           Budget[]

  @@index([responsibleUserId])
  @@index([status])
  @@map("projects")
}

model Budget {
  id                    String       @id @default(uuid()) @db.Uuid
  projectId             String       @map("project_id") @db.Uuid
  versionNumber         Int          @map("version_number")
  status                BudgetStatus @default(RASCUNHO)
  inputData             Json         @map("input_data") @db.JsonB
  subtotal              Decimal      @db.Decimal(14, 2)
  complexityMultiplier  Decimal      @map("complexity_multiplier") @db.Decimal(8, 4)
  urgencyMultiplier     Decimal      @map("urgency_multiplier") @db.Decimal(8, 4)
  discountPercentage    Decimal      @map("discount_percentage") @db.Decimal(5, 2)
  finalTotal            Decimal      @map("final_total") @db.Decimal(14, 2)
  monthlyRecurringTotal Decimal      @map("monthly_recurring_total") @db.Decimal(14, 2)
  notes                 String?      @db.Text
  createdById           String       @map("created_by_id") @db.Uuid
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  project               Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy             User         @relation("BudgetCreator", fields: [createdById], references: [id])
  items                 BudgetItem[]

  @@unique([projectId, versionNumber])
  @@index([projectId, status])
  @@index([createdById])
  @@map("budgets")
}

model BudgetItem {
  id           String   @id @default(uuid()) @db.Uuid
  budgetId     String   @map("budget_id") @db.Uuid
  code         String   @db.VarChar(100)
  name         String   @db.VarChar(160)
  description  String?  @db.Text
  category     String   @db.VarChar(80)
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(14, 2)
  totalPrice   Decimal  @map("total_price") @db.Decimal(14, 2)
  recurring    Boolean  @default(false)
  metadata     Json?    @db.JsonB
  displayOrder Int      @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  budget       Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId, displayOrder])
  @@map("budget_items")
}

model PricingConfig {
  id              String            @id @default(uuid()) @db.Uuid
  code            String            @unique @db.VarChar(100)
  name            String            @db.VarChar(160)
  applicationType ApplicationType   @map("application_type")
  category        String            @db.VarChar(80)
  configType      PricingConfigType @map("config_type")
  value           Decimal           @db.Decimal(14, 4)
  active          Boolean           @default(true)
  metadata        Json?             @db.JsonB
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([applicationType, active])
  @@map("pricing_configs")
}
